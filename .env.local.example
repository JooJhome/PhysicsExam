# คัดลอกเป็น .env.local แล้วใส่ค่าจริงจาก Supabase project (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# service-role key — ใช้ฝั่งเซิร์ฟเวอร์เท่านั้น (สร้าง user, batch seed) ห้าม commit / ห้ามขึ้น client
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# โดเมนสังเคราะห์สำหรับ map username -> email ของนักเรียน
NEXT_PUBLIC_STUDENT_EMAIL_DOMAIN=students.bsiink.local
